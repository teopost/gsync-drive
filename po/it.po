msgstr "Informazioni"

msgid "Cancel"
msgstr "Annulla"

msgid "Repair"
msgstr "Ripristina"

msgid "{minutes} min ago"
msgstr "{minutes} min fa"

msgid "{hours} h ago"
msgstr "{hours} h fa"

msgid "Synchronize now"
msgstr "Sincronizza ora"

msgid "Add Google account"
msgstr "Aggiungi account Google"

msgid "Accounts"
msgstr "Account"

msgid "No account configured"
msgstr "Nessun account configurato"

msgid "Connect a Google account to start synchronizing."
msgstr "Collega un account Google per iniziare a sincronizzare."

msgid "Service not running"
msgstr "Servizio non in esecuzione"

msgid "Synchronization log"
msgstr "Log di sincronizzazione"

msgid "Remove the account?"
msgstr "Rimuovere l'account?"

msgid "Computing what the repair would involve…"
msgstr "Sto calcolando cosa comporterebbe il ripristino…"

msgid "The synchronization service is not responding.\nStart it with: {command}"
msgstr "Il servizio di sincronizzazione non risponde.\nAvvialo con: {command}"

msgid "{account}: synchronization interrupted, needs attention"
msgstr "{account}: sincronizzazione interrotta, serve una verifica"

msgid "Synchronization of “{account}” will stop.\nThe local files in {folder} will NOT be deleted."
msgstr "La sincronizzazione di “{account}” verrà interrotta.\nI file locali in {folder} NON verranno cancellati."

msgid "Bidirectional Google Drive synchronization for GNOME, based on rclone."
msgstr "Sincronizzazione bidirezionale con Google Drive per GNOME, basata su rclone."

msgid "Repair of “{account}”"
msgstr "Ripristino di “{account}”"

msgid "The repair realigns both sides and resumes synchronization.\n\n⚠ For files that differ on both sides, the LOCAL version wins.\n⚠ Files deleted on one side only after the last successful synchronization will be RESTORED.\n\nExpected operations: about {changes}."
msgstr "Il ripristino riallinea i due lati e riprende la sincronizzazione.\n\n⚠ Per i file diversi su entrambi i lati vince la versione LOCALE.\n⚠ I file cancellati da un solo lato dopo l'ultima sincronizzazione riuscita verranno RIPRISTINATI.\n\nOperazioni previste: circa {changes}."

msgid "Preview not available ({error}). You can proceed anyway."
msgstr "Anteprima non disponibile ({error}). Puoi comunque procedere."

msgid "Log not available: {message}"
msgstr "Log non disponibile: {message}"

msgid "Connect Google account"
msgstr "Collega account Google"

msgid "Next"
msgstr "Avanti"

msgid "Waiting for the authorization in the browser…"
msgstr "In attesa dell'autorizzazione nel browser…"

msgid "Drive folders"
msgstr "Cartelle di Drive"

msgid "Start first synchronization"
msgstr "Avvia prima sincronizzazione"

msgid "Folder"
msgstr "Cartella"

msgid "Done"
msgstr "Fine"

msgid "Analyzing files…"
msgstr "Analisi dei file…"

msgid "Back to setup"
msgstr "Torna alla configurazione"

msgid "Stop and cancel"
msgstr "Ferma e annulla"

msgid "Add Google Drive account"
msgstr "Aggiungi account Google Drive"

msgid "Connect your Google account"
msgstr "Collega il tuo account Google"

msgid "Your browser will open to authorize access to Google Drive.\nCredentials stay on this computer only."
msgstr "Si aprirà il browser per autorizzare l'accesso a Google Drive.\nLe credenziali restano solo su questo computer."

msgid "Account connected ✓"
msgstr "Account collegato ✓"

msgid "Folders to synchronize"
msgstr "Cartelle da sincronizzare"

msgid "Check the Drive folders you want to keep on this computer. With no selection, the whole Drive is synchronized."
msgstr "Seleziona le cartelle di Drive da tenere su questo computer. Senza selezione viene sincronizzato tutto il Drive."

msgid "Whole Drive"
msgstr "Tutto il Drive"

msgid "Local folder"
msgstr "Cartella locale"

msgid "Choose where to keep the files synchronized with Google Drive."
msgstr "Scegli dove tenere i file sincronizzati con Google Drive."

msgid "Account name (e.g. Personal, Work)"
msgstr "Nome account (es. Personale, Lavoro)"

msgid "Show in the Files sidebar"
msgstr "Mostra nella barra laterale di File"

msgid "Choose the synchronization folder"
msgstr "Scegli la cartella di sincronizzazione"

msgid "You can close this window: the synchronization can continue in the background."
msgstr "Puoi chiudere questa finestra: la sincronizzazione può proseguire in background."

msgid "Show details"
msgstr "Mostra dettagli"

msgid "Completed"
msgstr "Completato"

msgid "All set"
msgstr "Tutto pronto"

msgid "Synchronization failed"
msgstr "Sincronizzazione non riuscita"

msgid "First synchronization in progress"
msgstr "Prima sincronizzazione in corso"

msgid "Do you want the synchronization to continue in the background, or would you rather stop it and cancel this account setup?"
msgstr "Vuoi che la sincronizzazione prosegua in background o preferisci fermarla e annullare la configurazione di questo account?"

msgid "Continue in background"
msgstr "Prosegui in background"

msgid "rclone not found"
msgstr "rclone non trovato"

msgid "GDrive Sync uses rclone as its synchronization engine.\nInstall the “rclone” package and reopen this assistant."
msgstr "GDrive Sync usa rclone come motore di sincronizzazione.\nInstalla il pacchetto “rclone” e riapri questa procedura."

msgid "Unknown error"
msgstr "Errore sconosciuto"

msgid "the remote does not respond after configuration"
msgstr "il remote non risponde dopo la configurazione"

msgid "Timed out: authorization not completed."
msgstr "Tempo scaduto: autorizzazione non completata."

msgid "Error: {message}"
msgstr "Errore: {message}"

msgid "{count} selected: {folders}"
msgstr "{count} selezionate: {folders}"

msgid "The folder {folder} is synchronized with Google Drive."
msgstr "La cartella {folder} è sincronizzata con Google Drive."

msgid "authorization cancelled"
msgstr "autorizzazione annullata"

msgid "Transferring… {percent}%"
msgstr "Trasferimento… {percent}%"

msgid "rclone {major}.{minor} detected: sync works but is more robust with rclone ≥ 1.66 (rclone.org)"
msgstr "rclone {major}.{minor} rilevato: la sync funziona ma è più robusta con rclone ≥ 1.66 (rclone.org)"

msgid "{n} file modified both locally and on Drive needs a decision."
msgid_plural "{n} files modified both locally and on Drive need a decision."
msgstr[0] "{n} file modificato sia in locale che su Drive richiede una scelta."
msgstr[1] "{n} file modificati sia in locale che su Drive richiedono una scelta."

msgid "{n} conflict"
msgid_plural "{n} conflicts"
msgstr[0] "{n} conflitto"
msgstr[1] "{n} conflitti"

msgid "Service not available"
msgstr "Servizio non disponibile"

msgid "Apply"
msgstr "Applica"

msgid "Synchronized folders"
msgstr "Cartelle sincronizzate"

msgid "Edit…"
msgstr "Modifica…"

msgid "With no selection, the whole Drive is synchronized."
msgstr "Senza selezione viene sincronizzato tutto il Drive."

msgid "Apply the new folder selection?"
msgstr "Applicare la nuova selezione di cartelle?"

msgid "The synchronization will be realigned now (resync). Folders removed from the selection stay on this computer but are no longer synchronized."
msgstr "La sincronizzazione verrà riallineata adesso (resync). Le cartelle rimosse dalla selezione restano su questo computer ma non vengono più sincronizzate."

msgid "Folder selection updated; realigning…"
msgstr "Selezione delle cartelle aggiornata; riallineamento in corso…"

msgid "Realign not started: {message}"
msgstr "Riallineamento non avviato: {message}"

msgid "Open GDrive Sync"
msgstr "Apri GDrive Sync"

msgid "Resume synchronization"
msgstr "Riprendi la sincronizzazione"

msgid "Pause synchronization"
msgstr "Sospendi la sincronizzazione"

msgid "Tray icon"
msgstr "Icona nell'area di notifica"

msgid "Applies to all accounts; on GNOME it requires the AppIndicator extension"
msgstr "Vale per tutti gli account; su GNOME richiede l'estensione AppIndicator"

msgid "Preferences"
msgstr "Preferenze"

msgid "On GNOME it requires the AppIndicator extension"
msgstr "Su GNOME richiede l'estensione AppIndicator"

msgid "Diagnostics"
msgstr "Diagnostica"

msgid "Service log"
msgstr "Log del servizio"

msgid "Messages from the synchronization service"
msgstr "Messaggi del servizio di sincronizzazione"

msgid "Realigning…"
msgstr "Riallineamento…"

msgid "Configuration unavailable"
msgstr "Configurazione non disponibile"

msgid "The application settings schema is not installed (this can happen right after an update). Log out and back in, or reinstall the package, then reopen GDrive Sync."
msgstr "Lo schema delle impostazioni dell'applicazione non è installato (può capitare subito dopo un aggiornamento). Esci e rientra dalla sessione, oppure reinstalla il pacchetto, poi riapri GDrive Sync."

msgid "Close"
msgstr "Chiudi"

