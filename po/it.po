msgid "A manual check is needed before resuming. Open GDrive Sync for the guided repair."
msgstr "Serve una verifica manuale prima di riprendere. Apri GDrive Sync per il ripristino guidato."

msgid "A bisync lock persists: another synchronization may be running, or a previous one was interrupted abruptly."
msgstr "Un lock di bisync persiste: un'altra sincronizzazione potrebbe essere in corso, oppure una precedente è stata interrotta bruscamente."

msgid "{account}: synchronization interrupted"
msgstr "{account}: sincronizzazione interrotta"

msgid "rclone remote {remote} is missing"
msgstr "remote rclone {remote} mancante"

msgid "Synchronization stopped due to an error. Open GDrive Sync for details."
msgstr "La sincronizzazione si è fermata per un errore. Apri GDrive Sync per i dettagli."

msgid "{account}: first synchronization completed"
msgstr "{account}: prima sincronizzazione completata"

msgid "The folder {folder} is now synchronized with Google Drive."
msgstr "La cartella {folder} è ora sincronizzata con Google Drive."

msgid "{account}: synchronization conflicts"
msgstr "{account}: conflitti di sincronizzazione"

msgid "temporary error"
msgstr "errore temporaneo"

msgid "Google Drive has been unreachable for several attempts."
msgstr "Google Drive non è raggiungibile da diversi tentativi."

msgid "fatal error"
msgstr "errore fatale"

msgid "{account}: synchronization error"
msgstr "{account}: errore di sincronizzazione"

msgid "{account}: synchronization failing"
msgstr "{account}: sincronizzazione in errore"

msgid "Review"
msgstr "Rivedi"

msgid "No conflicts"
msgstr "Nessun conflitto"

msgid "All files are aligned."
msgstr "Tutti i file sono allineati."

msgid "These files were modified both locally and on Drive. Choose which version to keep; the choice will be applied at the next synchronization."
msgstr "Questi file sono stati modificati sia in locale che su Drive. Scegli quale versione tenere; la scelta verrà applicata alla prossima sincronizzazione."

