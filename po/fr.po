msgid "Do you want the synchronization to continue in the background, or would you rather stop it and cancel this account setup?"
msgstr "Voulez-vous que la synchronisation continue en arrière-plan, ou préférez-vous l'arrêter et annuler la configuration de ce compte ?"

msgid "Continue in background"
msgstr "Continuer en arrière-plan"

msgid "rclone not found"
msgstr "rclone introuvable"

msgid "GDrive Sync uses rclone as its synchronization engine.\nInstall the “rclone” package and reopen this assistant."
msgstr "GDrive Sync utilise rclone comme moteur de synchronisation.\nInstallez le paquet « rclone » et rouvrez cet assistant."

msgid "Unknown error"
msgstr "Erreur inconnue"

msgid "the remote does not respond after configuration"
msgstr "le remote ne répond pas après la configuration"

