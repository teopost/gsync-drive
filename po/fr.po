msgstr "rclone {major}.{minor} détecté : la synchronisation fonctionne mais est plus robuste avec rclone ≥ 1.66 (rclone.org)"

msgid "{n} file modified both locally and on Drive needs a decision."
msgid_plural "{n} files modified both locally and on Drive need a decision."
msgstr[0] "{n} fichier modifié à la fois localement et sur Drive nécessite un choix."
msgstr[1] "{n} fichiers modifiés à la fois localement et sur Drive nécessitent un choix."

