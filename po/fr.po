msgstr "{account} : synchronisation interrompue, vérification nécessaire"

msgid "Synchronization of “{account}” will stop.\nThe local files in {folder} will NOT be deleted."
msgstr "La synchronisation de « {account} » sera interrompue.\nLes fichiers locaux dans {folder} ne seront PAS supprimés."

msgid "Bidirectional Google Drive synchronization for GNOME, based on rclone."
msgstr "Synchronisation bidirectionnelle avec Google Drive pour GNOME, basée sur rclone."

msgid "Repair of “{account}”"
msgstr "Réparation de « {account} »"

msgid "The repair realigns both sides and resumes synchronization.\n\n⚠ For files that differ on both sides, the LOCAL version wins.\n⚠ Files deleted on one side only after the last successful synchronization will be RESTORED.\n\nExpected operations: about {changes}."
msgstr "La réparation réaligne les deux côtés et reprend la synchronisation.\n\n⚠ Pour les fichiers différents des deux côtés, la version LOCALE l'emporte.\n⚠ Les fichiers supprimés d'un seul côté après la dernière synchronisation réussie seront RESTAURÉS.\n\nOpérations prévues : environ {changes}."

msgid "Preview not available ({error}). You can proceed anyway."
msgstr "Aperçu non disponible ({error}). Vous pouvez tout de même continuer."

