msgid "A manual check is needed before resuming. Open GDrive Sync for the guided repair."
msgstr "Une vérification manuelle est nécessaire avant de reprendre. Ouvrez GDrive Sync pour la réparation guidée."

msgid "A bisync lock persists: another synchronization may be running, or a previous one was interrupted abruptly."
msgstr "Un verrou bisync persiste : une autre synchronisation est peut-être en cours, ou une précédente a été interrompue brutalement."

msgid "{account}: synchronization interrupted"
msgstr "{account} : synchronisation interrompue"

msgid "rclone remote {remote} is missing"
msgstr "le remote rclone {remote} est introuvable"

msgid "Synchronization stopped due to an error. Open GDrive Sync for details."
msgstr "La synchronisation s'est arrêtée à cause d'une erreur. Ouvrez GDrive Sync pour les détails."

msgid "{account}: first synchronization completed"
msgstr "{account} : première synchronisation terminée"

